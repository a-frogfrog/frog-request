{
  "name": "frog-request",
  "version": "0.0.1",
  "private": false,
  "description": "A simple request library based on axios",
  "keywords": [
    "frog",
    "request"
  ],
  "license": "ISC",
  "author": {
    "name": "Silas",
    "email": "frogfrog7423@gmail.com"
  },
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "spellcheck": "cspell lint \"(packages|apps)/**/*.{js,ts,mjs,cjs,json,css,scss,md,html,tsx,jsx,less,sass,scss,vue}\"",
    "commit": "git-cz",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "dependencies": {
    "axios": "^1.12.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@cspell/dict-lorem-ipsum": "^4.0.5",
    "commitizen": "^4.3.1",
    "cspell": "^9.7.0",
    "cz-git": "^1.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "peerDependencies": {
    "axios": "^1.12.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "pnpm run lint:fix",
      "pnpm run fmt --no-error-on-unmatched-pattern"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "engines": {
    "node": ">=22.18.0",
    "npm": ">=11.4.2",
    "pnpm": ">=10.11.0"
  },
  "packageManager": "pnpm@10.11.0"
}
